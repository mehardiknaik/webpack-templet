{
    "presets": [
        [
            "@babel/preset-env",
            {
            "targets": {
                "chrome": "49",
                "firefox": "52",
                "safari": "10",
                "edge": "14"
            },
                "useBuiltIns": "usage",
                "corejs": "3.39",
                "modules": false
            }
        ],
        [
            "@babel/preset-react",
            {
                "runtime": "automatic"
            }
        ],
        "@babel/preset-typescript"
    ],
    "plugins": [
        [
            "@babel/plugin-transform-runtime",
            {
                "regenerator": false,
                "useESModules": true
            }
        ]
    ]
}